/playwright/.auth/

# IDEs and Editors
.vscode/
.idea/

# System Files
Thumbs.db
desktop.ini

# analytics & supabase
/supabase/
/sync_logs/

# Machine Learning & Python
.venv/
ml/venv/
__pycache__/
ml/catboost_info/
